# Postgres (Railway provides this as DATABASE_URL on the linked Postgres service)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth.js
AUTH_SECRET=                       # openssl rand -base64 32
AUTH_URL=http://localhost:3000     # in production: https://deanst-dashboard-production.up.railway.app

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=deanst-documents
R2_ENDPOINT=                       # https://<account>.r2.cloudflarestorage.com (auto-derived if blank)

# Resend (invite emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Dean St <invites@deanst.co>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000   # in production: https://deanst-dashboard-production.up.railway.app
